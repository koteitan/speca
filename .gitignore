# Benchmark datasets (local only)
benchmarks/data/**/*.jsonl
benchmarks/data/**/*.db
benchmarks/data/**/*.sqlite
benchmarks/data/**/raw/
.mcp.json
outputs/.mcp_configs/

# Benchmark results — bulky raw outputs are published as GitHub Release
# assets (`bench-<rq>-<date>-...`) instead of being committed. We do
# allow small documentation artifacts (charts, paper figures, human
# review guides) so the in-repo README renders correctly on GitHub.
# (gitignore does NOT strip trailing comments — keep these on their own
#  lines, otherwise the comment becomes part of the pattern.)
benchmarks/results/**
# Re-include directory entries so children can be selectively un-ignored.
!benchmarks/results/**/
!benchmarks/results/.gitkeep
# Rendered figures referenced from README.md.
!benchmarks/results/**/*.png
# Paper-style tables (e.g. rq2b_table.tex).
!benchmarks/results/**/*.tex
# Human-readable guides (REVIEW_GUIDE.md, etc.).
!benchmarks/results/**/*.md
# Locally built bench artifacts before they are uploaded to a Release.
dist/bench-artifacts/

# Audit-finding CSVs — the canonical store is HuggingFace
# (NyxFoundation/vulnerability-reports). Local CSVs are scratch input for
# the publish pipeline; if you re-scrape, output lands under
# benchmarks/data/defi_audit_reports/ (handled by the rules above for
# heavier files like *.jsonl/*.db). Don't re-add csv/.
csv/
# Locally built dataset artifacts before they're pushed to HF.
dist/datasets/

# Claude Code worktrees
.claude/worktrees/

# Serena runtime state (modified by MCP server at runtime, not suitable for tracking)
.serena/project.yml

# Web client
web/node_modules/
web/dist/
web/frontend/node_modules/
web/frontend/dist/
!web/src/lib/
!web/frontend/src/lib/

# Friend's submission drafts — NEVER commit
outputs/submitted/friend/

# Per-target audit experiment outputs — NEVER commit to speca
# (These belong in a separate fork/repo. Patterns here keep speca clean
# even when SPECA_OUTPUT_DIR points at a sibling/test directory.)
outputs/test-*/
outputs-*/

# Per-run trace archives (issue #32 — archive substrate)
.speca/
