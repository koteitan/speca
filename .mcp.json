{
  "mcpServers": {
    "tree_sitter": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-tree-sitter"
      ],
      "env": {}
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server"
      ],
      "env": {}
    },
    "semgrep": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "semgrep-mcp"
      ],
      "env": {}
    }
  }
}