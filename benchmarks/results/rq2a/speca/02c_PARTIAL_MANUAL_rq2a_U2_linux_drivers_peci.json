    {
      "property_id": "PROP-U2-uaf-003",
      "text": "auxiliary_device_uninit() in adev_release() calls put_device() which frees the containing struct when refcount reaches 0 via the release callback; any subsequent access to adev->name or kfree(adev) is a use-after-free",
      "type": "invariant",
      "assertion": "forall callee(f) in adev_release where f transitively calls put_device/kobject_put that may free(adev): no_use(adev) AND no_use(adev->name) after call(f)",
      "severity": "HIGH",
      "covers": "FN-U2-003",
      "reachability": {
        "classification": "external-reachable",
        "entry_points": [
          "FunctionCall"
        ],
        "attacker_controlled": true,
        "bug_bounty_scope": "in-scope"
      },
