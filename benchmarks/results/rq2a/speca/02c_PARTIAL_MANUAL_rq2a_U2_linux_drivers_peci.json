              "start": 187,
              "end": 195
            },
            "role": "primary",
            "note": "L189: auxiliary_device_uninit(adev) may free adev via put_device; L191: kfree(adev->name) dereferences potentially-freed adev; L192: kfree(adev) double-frees"
          },
          {
            "file": "drivers/auxiliary/bus.c",
            "symbol": "auxiliary_device_uninit",
            "line_range": {
              "start": 1,
              "end": 50
