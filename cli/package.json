{
  "name": "speca-cli",
  "version": "0.1.0-alpha.0",
  "description": "TUI front-end for the SPECA security-audit pipeline",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "speca": "./dist/cli.js",
    "speca-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "sync-schemas": "node scripts/sync-schemas.mjs",
    "build": "npm run sync-schemas && tsc",
    "dev": "tsx src/cli.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "cli-highlight": "^2.1.11",
    "fast-glob": "^3.3.2",
    "ink": "^7.0.1",
    "meow": "^13.2.0",
    "react": "^19.0.0",
    "which": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/which": "^3.0.4",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NyxFoundation/speca.git",
    "directory": "cli"
  },
  "keywords": [
    "speca",
    "security",
    "audit",
    "cli",
    "tui",
    "ink"
  ]
}
