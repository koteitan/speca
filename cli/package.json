{
  "name": "speca-cli",
  "version": "0.9.0",
  "description": "TUI front-end for the SPECA security-audit pipeline",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "speca": "./dist/cli.js",
    "speca-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "TESTING.md"
  ],
  "scripts": {
    "sync-schemas": "node scripts/sync-schemas.mjs",
    "build": "npm run sync-schemas && tsc",
    "dev": "tsx src/cli.tsx",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "stryker": "stryker run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "chokidar": "^5.0.0",
    "cli-highlight": "^2.1.11",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.2",
    "ink": "^7.0.1",
    "meow": "^13.2.0",
    "react": "^19.0.0",
    "smol-toml": "^1.6.1",
    "which": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/which": "^3.0.4",
    "@vitest/coverage-v8": "^2.1.9",
    "fast-check": "^4.7.0",
    "ink-testing-library": "^4.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "json-schema-to-zod": "^2.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NyxFoundation/speca.git",
    "directory": "cli"
  },
  "keywords": [
    "speca",
    "security",
    "audit",
    "cli",
    "tui",
    "ink"
  ],
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  }
}
