---
title: "isValidSignature (GPV2CompatibleAuction)"
---
stateDiagram-v2
    direction TB
    [*] --> q_decode: order = abi.decode(signature, GPv2Order.Data)
    q_decode --> q_check_reentrant: decode complete
    q_check_reentrant --> q_revert_reentrant: s_entered == true
    q_revert_reentrant --> [*]: revert Errors.ReentrantCall()
    q_check_reentrant --> q_check_hash: s_entered == false
    q_check_hash --> q_revert_hash: hash != GPv2Order.hash(order, domainSeparator)
    q_revert_hash --> [*]: revert InvalidOrderId(hash)
    q_check_hash --> q_check_auction: hash matches order
    q_check_auction --> q_revert_auction1: auctionStart == 0
    q_revert_auction1 --> [*]: revert InvalidAuction(sellToken)
    q_check_auction --> q_check_buytoken: auctionStart != 0
    q_check_buytoken --> q_revert_buytoken: buyToken != s_assetOut
    q_revert_buytoken --> [*]: revert InvalidBuyToken(buyToken, s_assetOut)
    q_check_buytoken --> q_check_receiver: buyToken == s_assetOut
    q_check_receiver --> q_revert_receiver: receiver != address(this)
    q_revert_receiver --> [*]: revert InvalidReceiver(receiver, this)
    q_check_receiver --> q_check_sell_zero: receiver == address(this)
    q_check_sell_zero --> q_revert_zero_amt: sellAmount == 0
    q_revert_zero_amt --> [*]: revert Errors.InvalidZeroAmount()
    q_check_sell_zero --> q_check_balance: sellAmount != 0
    q_check_balance --> q_revert_balance: sellAmount > assetInBalance
    q_revert_balance --> [*]: revert InsufficientAssetInBalance(sellToken, sellAmount, balance)
    q_check_balance --> q_check_elapsed: sellAmount <= assetInBalance
    q_check_elapsed --> q_revert_auction2: elapsedTime > auctionDuration
    q_revert_auction2 --> [*]: revert InvalidAuction(sellToken)
    q_check_elapsed --> q_check_price: elapsedTime <= auctionDuration
    q_check_price --> q_revert_price: buyAmount < minBuyAmount
    q_revert_price --> [*]: revert InsufficientBuyAmount(buyAmount, minBuyAmount)
    q_check_price --> q_check_expiry: buyAmount >= minBuyAmount
    q_check_expiry --> q_revert_expiry: validTo < block.timestamp
    q_revert_expiry --> [*]: revert ExpiredOrder(validTo, block.timestamp)
    q_check_expiry --> q_check_fee: validTo >= block.timestamp
    q_check_fee --> q_revert_fee: feeAmount > 0
    q_revert_fee --> [*]: revert InvalidFeeAmount()
    q_check_fee --> q_check_kind: feeAmount == 0
    q_check_kind --> q_revert_kind: kind != KIND_SELL
    q_revert_kind --> [*]: revert InvalidOrderKind(kind)
    q_check_kind --> q_check_partial: kind == KIND_SELL
    q_check_partial --> q_revert_partial: partiallyFillable == false
    q_revert_partial --> [*]: revert OrderNotPartiallyFillable()
    q_check_partial --> q_check_token_bal: partiallyFillable == true
    q_check_token_bal --> q_revert_token_bal: sellTokenBalance != BALANCE_ERC20 OR buyTokenBalance != BALANCE_ERC20
    q_revert_token_bal --> [*]: revert InvalidTokenBalanceMarker()
    q_check_token_bal --> [*]: return IERC1271.isValidSignature.selector

    note right of q_check_reentrant
        INV-001: Function is view-only, cannot modify state
        INV-002: Reentrancy check prevents validation during bid() execution
    end note

    note right of q_check_price
        INV-003: minBuyAmount derived from _getAssetOutAmount using Dutch auction price curve
        INV-004: Price decreases linearly from startingPriceMultiplier to endingPriceMultiplier over auctionDuration
    end note

    note right of q_check_token_bal
        INV-005: Only ERC20 direct balance transfers supported (no Balancer vault)
        INV-006: Order must be partially fillable (CowProtocol can fill in portions)
        INV-007: Zero fee required (no surplus fee extraction)
    end note
