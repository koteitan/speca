---
title: "performUpkeep (BaseAuction)"
---
stateDiagram-v2
    direction TB
    [*] --> q_decode: decode (eligibleAssets, endedAuctions) from performData
    q_decode --> q_get_out_price: eligibleAssets.length > 0
    q_decode --> q_end_loop: eligibleAssets.length == 0
    q_get_out_price --> q_pull_funds: assetOutPrice = _getAssetPrice(assetOut, true)
    q_pull_funds --> q_start_loop: feeAggregator.transferForSwap(this, eligibleAssets)
    q_start_loop --> q_check_live_start: for each eligible asset
    q_check_live_start --> q_error_live: auctionStart != 0
    q_error_live --> [*]: revert LiveAuction
    q_check_live_start --> q_check_params: auctionStart == 0
    q_check_params --> q_error_params: decimals == 0
    q_error_params --> [*]: revert AssetParamsNotSet
    q_check_params --> q_get_asset_price: decimals > 0
    q_get_asset_price --> q_check_min_size: validate assetPrice
    q_check_min_size --> q_error_min: usdValue < minAuctionSizeUsd
    q_error_min --> [*]: revert AmountBelowMinAuctionSize
    q_check_min_size --> q_is_assetout: usdValue >= minAuctionSizeUsd
    q_is_assetout --> q_transfer_out: asset == assetOut
    q_transfer_out --> q_start_loop: transfer balance to assetOutReceiver
    q_is_assetout --> q_mark_start: asset != assetOut
    q_mark_start --> q_start_loop: s_auctionStarts[asset] = block.timestamp
    q_start_loop --> q_end_loop: all eligible assets processed
    q_end_loop --> q_check_end: for each ended auction
    q_check_end --> q_error_invalid: auctionStart == 0
    q_error_invalid --> [*]: revert InvalidAuction
    q_check_end --> q_on_end: auctionStart != 0
    q_on_end --> q_end_loop: _onAuctionEnd(asset), delete auctionStart
    q_end_loop --> [*]: all ended auctions processed

    note right of q_mark_start
        INV-001: No auction starts if asset already has live auction
        INV-002: Asset parameters must be configured before auction start
        INV-003: Asset value must exceed minimum auction size
        INV-004: AssetOut is forwarded directly to receiver, not auctioned
    end note
