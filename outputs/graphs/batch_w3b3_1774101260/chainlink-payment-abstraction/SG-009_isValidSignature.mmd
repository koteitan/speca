---
title: "isValidSignature (GPV2CompatibleAuction)"
---
stateDiagram-v2
    direction TB
    [*] --> q_decode: order = abi.decode(signature)
    q_decode --> q_check_reenter: check s_entered
    q_check_reenter --> q_error_reenter: s_entered == true
    q_error_reenter --> [*]: revert ReentrantCall
    q_check_reenter --> q_check_hash: s_entered == false
    q_check_hash --> q_error_hash: hash != GPv2Order.hash(order, domainSeparator)
    q_error_hash --> [*]: revert InvalidOrderId
    q_check_hash --> q_check_auction: hash matches
    q_check_auction --> q_error_auction: auctionStart == 0
    q_error_auction --> [*]: revert InvalidAuction
    q_check_auction --> q_check_buy: auctionStart != 0
    q_check_buy --> q_error_buy: buyToken != assetOut
    q_error_buy --> [*]: revert InvalidBuyToken
    q_check_buy --> q_check_receiver: buyToken == assetOut
    q_check_receiver --> q_error_recv: receiver != address(this)
    q_error_recv --> [*]: revert InvalidReceiver
    q_check_receiver --> q_check_sell_zero: receiver == address(this)
    q_check_sell_zero --> q_error_zero: sellAmount == 0
    q_error_zero --> [*]: revert InvalidZeroAmount
    q_check_sell_zero --> q_check_balance: sellAmount > 0
    q_check_balance --> q_error_bal: sellAmount > assetInBalance
    q_error_bal --> [*]: revert InsufficientAssetInBalance
    q_check_balance --> q_check_elapsed: sellAmount <= balance
    q_check_elapsed --> q_error_expired_auction: elapsedTime > auctionDuration
    q_error_expired_auction --> [*]: revert InvalidAuction
    q_check_elapsed --> q_calc_min: within duration
    q_calc_min --> q_check_buy_amt: minBuyAmount = _getAssetOutAmount(...)
    q_check_buy_amt --> q_error_buy_amt: buyAmount < minBuyAmount
    q_error_buy_amt --> [*]: revert InsufficientBuyAmount
    q_check_buy_amt --> q_check_validto: buyAmount >= minBuyAmount
    q_check_validto --> q_error_expired: validTo < block.timestamp
    q_error_expired --> [*]: revert ExpiredOrder
    q_check_validto --> q_check_fee: not expired
    q_check_fee --> q_error_fee: feeAmount > 0
    q_error_fee --> [*]: revert InvalidFeeAmount
    q_check_fee --> q_check_kind: feeAmount == 0
    q_check_kind --> q_error_kind: kind != KIND_SELL
    q_error_kind --> [*]: revert InvalidOrderKind
    q_check_kind --> q_check_partial: kind == KIND_SELL
    q_check_partial --> q_error_partial: !partiallyFillable
    q_error_partial --> [*]: revert OrderNotPartiallyFillable
    q_check_partial --> q_check_bal_marker: partiallyFillable == true
    q_check_bal_marker --> q_error_marker: invalid balance markers
    q_error_marker --> [*]: revert InvalidTokenBalanceMarker
    q_check_bal_marker --> [*]: return isValidSignature.selector

    note right of q_calc_min
        INV-001: Order hash must match GPv2 domain separator hash
        INV-002: Buy amount must meet or exceed current auction curve price
        INV-003: Only partially fillable sell orders with zero fee are accepted
        INV-004: ERC20 direct balance mode required for both tokens
        INV-005: Receiver must be the auction contract itself (for assetOut collection)
    end note
