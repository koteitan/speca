{
  "$defs": {
    "AuditTrail": {
      "description": "Complete audit trail from the three-phase formal audit.",
      "properties": {
        "phase1_abstract_interpretation": {
          "$ref": "#/$defs/Phase1AbstractInterpretation"
        },
        "phase2_5_reachability_analysis": {
          "$ref": "#/$defs/Phase2_5ReachabilityAnalysis"
        },
        "phase2_symbolic_execution": {
          "$ref": "#/$defs/Phase2SymbolicExecution"
        },
        "phase3_5_scope_filtering": {
          "$ref": "#/$defs/Phase3_5ScopeFiltering"
        },
        "phase3_invariant_proving": {
          "$ref": "#/$defs/Phase3InvariantProving"
        }
      },
      "title": "AuditTrail",
      "type": "object"
    },
    "CodeLocation": {
      "description": "A single code location (file + symbol + line range).",
      "properties": {
        "file": {
          "title": "File",
          "type": "string"
        },
        "line_range": {
          "$ref": "#/$defs/LineRange"
        },
        "note": {
          "default": "",
          "title": "Note",
          "type": "string"
        },
        "role": {
          "default": "primary",
          "title": "Role",
          "type": "string"
        },
        "symbol": {
          "title": "Symbol",
          "type": "string"
        }
      },
      "required": [
        "file",
        "symbol",
        "line_range"
      ],
      "title": "CodeLocation",
      "type": "object"
    },
    "CodeScope": {
      "description": "Code location information for a checklist item.\n\nSupports multiple related code locations for comprehensive coverage.\nFor example, a security check might involve:\n- Primary: the function being tested\n- Callers: functions that call the primary\n- Callees: functions called by the primary\n- Related: other relevant code locations",
      "properties": {
        "locations": {
          "items": {
            "$ref": "#/$defs/CodeLocation"
          },
          "title": "Locations",
          "type": "array"
        },
        "resolution_error": {
          "default": "",
          "title": "Resolution Error",
          "type": "string"
        },
        "resolution_status": {
          "default": "",
          "title": "Resolution Status",
          "type": "string"
        }
      },
      "title": "CodeScope",
      "type": "object"
    },
    "LineRange": {
      "description": "Line range in a source file.",
      "properties": {
        "end": {
          "title": "End",
          "type": "integer"
        },
        "start": {
          "title": "Start",
          "type": "integer"
        }
      },
      "required": [
        "start",
        "end"
      ],
      "title": "LineRange",
      "type": "object"
    },
    "Phase1AbstractInterpretation": {
      "description": "Phase 1 audit trail: abstract interpretation results.",
      "properties": {
        "state_anomalies_found": {
          "items": {},
          "title": "State Anomalies Found",
          "type": "array"
        },
        "summary": {
          "default": "",
          "title": "Summary",
          "type": "string"
        }
      },
      "title": "Phase1AbstractInterpretation",
      "type": "object"
    },
    "Phase2SymbolicExecution": {
      "description": "Phase 2 audit trail: symbolic execution results.",
      "properties": {
        "counterexample": {
          "default": null,
          "title": "Counterexample"
        },
        "counterexample_found": {
          "default": false,
          "title": "Counterexample Found",
          "type": "boolean"
        },
        "summary": {
          "default": "",
          "title": "Summary",
          "type": "string"
        }
      },
      "title": "Phase2SymbolicExecution",
      "type": "object"
    },
    "Phase2_5ReachabilityAnalysis": {
      "description": "Phase 2.5 audit trail: reachability analysis results.",
      "properties": {
        "attacker_controlled": {
          "default": false,
          "title": "Attacker Controlled",
          "type": "boolean"
        },
        "classification": {
          "default": "unreachable",
          "title": "Classification",
          "type": "string"
        },
        "data_flow_path": {
          "default": "",
          "title": "Data Flow Path",
          "type": "string"
        },
        "entry_points": {
          "items": {
            "type": "string"
          },
          "title": "Entry Points",
          "type": "array"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "summary": {
          "default": "",
          "title": "Summary",
          "type": "string"
        },
        "validation_layers": {
          "items": {
            "type": "string"
          },
          "title": "Validation Layers",
          "type": "array"
        }
      },
      "title": "Phase2_5ReachabilityAnalysis",
      "type": "object"
    },
    "Phase3InvariantProving": {
      "description": "Phase 3 audit trail: invariant proving results.",
      "properties": {
        "guard_identified": {
          "default": null,
          "title": "Guard Identified"
        },
        "proof_successful": {
          "default": false,
          "title": "Proof Successful",
          "type": "boolean"
        },
        "summary": {
          "default": "",
          "title": "Summary",
          "type": "string"
        }
      },
      "title": "Phase3InvariantProving",
      "type": "object"
    },
    "Phase3_5ScopeFiltering": {
      "description": "Phase 3.5 audit trail: scope filtering results.",
      "properties": {
        "bug_bounty_eligible": {
          "default": false,
          "title": "Bug Bounty Eligible",
          "type": "boolean"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "reason": {
          "default": "",
          "title": "Reason",
          "type": "string"
        },
        "recommendation": {
          "default": "",
          "title": "Recommendation",
          "type": "string"
        }
      },
      "title": "Phase3_5ScopeFiltering",
      "type": "object"
    }
  },
  "description": "A single audit result from Phase 03.",
  "properties": {
    "attack_scenario": {
      "default": "",
      "title": "Attack Scenario",
      "type": "string"
    },
    "audit_trail": {
      "$ref": "#/$defs/AuditTrail"
    },
    "bug_bounty_eligible": {
      "default": false,
      "title": "Bug Bounty Eligible",
      "type": "boolean"
    },
    "checklist_id": {
      "default": "",
      "title": "Checklist Id",
      "type": "string"
    },
    "classification": {
      "default": "",
      "title": "Classification",
      "type": "string"
    },
    "code_path": {
      "anyOf": [
        {
          "$ref": "#/$defs/CodeScope"
        },
        {
          "type": "string"
        }
      ],
      "title": "Code Path"
    },
    "proof_trace": {
      "default": "",
      "title": "Proof Trace",
      "type": "string"
    },
    "property_id": {
      "title": "Property Id",
      "type": "string"
    },
    "summary": {
      "default": "",
      "title": "Summary",
      "type": "string"
    }
  },
  "required": [
    "property_id"
  ],
  "title": "AuditMapItem",
  "type": "object"
}
