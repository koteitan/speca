{
  "description": "Provenance record written to .speca/runs/<run-id>/manifest.json.\n\nOne manifest is created per invocation of run_phase.py (or per speca run\nfrom the CLI).  It accumulates cost/timing/prompt information as the run\nprogresses and is finalised by ``Archiver.finalize()``.",
  "properties": {
    "bug_bounty_scope_sha": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Bug Bounty Scope Sha"
    },
    "cli_version": {
      "default": "",
      "title": "Cli Version",
      "type": "string"
    },
    "cost_usd_total": {
      "default": 0.0,
      "title": "Cost Usd Total",
      "type": "number"
    },
    "ended_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Ended At"
    },
    "model": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Model",
      "type": "object"
    },
    "notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Notes"
    },
    "phases_completed": {
      "items": {
        "type": "string"
      },
      "title": "Phases Completed",
      "type": "array"
    },
    "prompt_shas": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Prompt Shas",
      "type": "object"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "spec_sources": {
      "items": {
        "type": "string"
      },
      "title": "Spec Sources",
      "type": "array"
    },
    "speca_commit": {
      "default": "",
      "title": "Speca Commit",
      "type": "string"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "target_info": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Info"
    }
  },
  "required": [
    "run_id",
    "started_at"
  ],
  "title": "RunManifest",
  "type": "object"
}
