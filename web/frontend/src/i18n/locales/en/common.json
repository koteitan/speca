  "glossary": {
    "CWE": "Common Weakness Enumeration — a standard taxonomy of software weaknesses (e.g. CWE-22 Path Traversal).",
    "STRIDE": "Threat modeling framework: Spoofing / Tampering / Repudiation / Information disclosure / Denial of service / Elevation of privilege.",
    "property": "A formal security property — an invariant of the form 'X always holds', generated by Phase 01e.",
    "subgraph": "State transition graph extracted from the spec. Mermaid format with invariants attached to each node. Output of Phase 01b.",
    "verdict": "The final Phase 04 verdict — one of six: CONFIRMED_VULNERABILITY / CONFIRMED_POTENTIAL / DISPUTED_FP / DOWNGRADED / NEEDS_MANUAL_REVIEW / PASS_THROUGH.",
    "severity": "Vulnerability severity — Critical / High / Medium / Low / Informational.",
    "phase 03": "Audit Map — proof-based verification that each property holds against target code.",
    "phase 04": "Review — a recall-safe 3-gate (Dead Code / Trust Boundary / Scope Check) false-positive filter pipeline.",
    "bug bounty scope": "The in-scope / out-of-scope definition of the target bug bounty program. Persisted in `BUG_BOUNTY_SCOPE.json`.",
    "trust boundary": "A line where external input reaches internal processing. Findings that cross this boundary are less likely to be false positives.",
    "dead code": "Phase 04 Gate 1 — rejects findings reported on code paths that cannot be reached at runtime.",
    "DISPUTED_FP": "A verdict marking a finding as a false positive, set by one of the three Phase 04 gates. Recall-safe design: only these three gates may emit FP verdicts.",
    "CONFIRMED_VULNERABILITY": "A finding confirmed by Phase 04 as a true vulnerability. The primary candidate for reporting."
  },
